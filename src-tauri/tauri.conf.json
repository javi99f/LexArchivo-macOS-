{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LexArchivo",
  "version": "0.1.1",
  "identifier": "com.lexarchivo.macos",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LexArchivo",
        "width": 1240,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/syncthing"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "LexArchivo",
    "category": "Business",
    "shortDescription": "Gestion local de expedientes juridicos",
    "longDescription": "Prototipo local para gestionar clientes, expedientes, cronologia, documentos y copias de seguridad."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFREI4NkVGNTMzMzJENUQKUldSZExUTlQ3NGJiSHFTaTE1cndWdUlOd2pWeUVRWncvejVQZHVDYnZYT2prUzVQUEluYkJHNlAK",
      "endpoints": [
        "https://github.com/javi99f/LexArchivo-macOS/releases/latest/download/latest.json"
      ]
    }
  }
}
